# How often to scrape (minutes)
SCRAPE_INTERVAL_MINUTES=15

# Browser mode — set to false for local development (shows browser window)
# Must be true on the server (no display available)
HEADLESS=true

# Proxy rotation
# Set to true and populate proxies.txt to route the scraper through a proxy
USE_PROXY=false

# Database path — defaults to chargers.db in the working directory
# Uncomment to use an absolute path:
# DATABASE_PATH=/data/chargers.db

# CORS origins for the API — use * for open access, or comma-separated origins
CORS_ORIGINS=*
